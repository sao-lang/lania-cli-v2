{
  "name": "lania",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types-entry.d.ts",
      "default": "./dist/types-entry.js"
    }
  },
  "typesVersions": {
    "*": {
      "types": [
        "./dist/types-entry.d.ts"
      ]
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test ./src/**/*.test.ts"
  },
  "dependencies": {
    "@lania-cli/node-bridge": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

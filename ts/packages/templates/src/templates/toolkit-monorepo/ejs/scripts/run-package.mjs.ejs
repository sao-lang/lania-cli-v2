import { spawn } from 'node:child_process';
import path from 'node:path';

const [, , relativeDir, scriptName, ...args] = process.argv;

if (!relativeDir || !scriptName) {
  console.error('Usage: node scripts/run-package.mjs <dir> <script> [...args]');
  process.exit(1);
}

const child = spawn(
  '<%= packageManager %>',
  ['run', scriptName, ...args],
  {
    cwd: path.resolve(process.cwd(), relativeDir),
    stdio: 'inherit',
    shell: process.platform === 'win32',
  },
);

child.on('exit', (code) => {
  process.exit(code ?? 1);
});

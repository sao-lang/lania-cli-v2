    packageManager: "<%= packageManager %>",
    lintTools: <%- JSON.stringify(lintTools) %>,
    buildTool: "<%= buildTool %>",
    release: {
        profile: "custom",
        verify: {
            lint: {
                enabled: true,
                command: "<%= packageManager %> run lint"
            },

{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 100,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "proseWrap": "preserve",
    "htmlWhitespaceSensitivity": "strict",
    "endOfLine": "lf",
    "useTabs": false,
    "tabWidth": 4,
    "quoteProps": "as-needed",
    "ignorePatterns": ["node_modules/**", "dist/**", "build/**", "**/vendor/**"]
}
